# Copy to `.env` and fill in real values. Never commit `.env`.

# MongoDB connection (Atlas or local)
# Example Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# Server
PORT=5000
NODE_ENV=development

# JWT authentication
JWT_SECRET=
JWT_EXPIRE=30d

# Optional: display name on generated PDFs (certificates, etc.)
COLLEGE_NAME=EduManager College

# Optional: library late-return fine per day (used by library controller)
LIBRARY_FINE_PER_DAY=2
